FROM ghcr.io/robotflow-labs/anima-serve:jazzy AS base

WORKDIR /app

COPY pyproject.toml README.md /app/
COPY src /app/src
COPY configs /app/configs

RUN pip install --no-cache-dir . && \
    pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cu128

EXPOSE 8080

ENV ANIMA_MODULE_NAME=turing-radar
ENV ANIMA_DEVICE=auto

CMD ["python", "-m", "uvicorn", "anima_turing_radar.api:create_app", \
     "--factory", "--host", "0.0.0.0", "--port", "8080"]
